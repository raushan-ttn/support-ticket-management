{
  "permissions": {
    "allow": [
      "Bash(npx tsc --noEmit*)",

      "Bash(npm run build*)",
      "Bash(npm run lint*)",
      "Bash(npm run format*)",
      "Bash(npm run db:migrate*)",
      "Bash(npm run db:seed*)",
      "Bash(npm run db:setup*)",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run dev*)",

      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git stash list*)",

      "Bash(ls*)",
      "Bash(find . *)",
      "Bash(grep*)"
    ],
    "deny": [
      "Bash(git commit --no-verify*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(rm -rf*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit 2>&1 | grep -E 'error TS|Found [0-9]+ error' | head -20"
          }
        ]
      }
    ]
  }
}
