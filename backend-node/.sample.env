# ─── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_pg_password_here
PG_DATABASE=ttn_stm
PG_POOL_MIN=2
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=5000
PG_SSL=false

# ─── Redis ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=stm:
REDIS_TTL_SECONDS=3600

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# ─── Admin Seed ──────────────────────────────────────────
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@ttn.com
ADMIN_PASSWORD=your_admin_password_here

# ─── CORS & Rate Limit ────────────────────────────────
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20

# ─── File Storage ─────────────────────────────────────
# backend: "local" for dev/test, "s3" for prod
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=public

# S3-compatible (prod / MinIO)
S3_BUCKET=support-tickets
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_access_key_id_here
S3_SECRET_ACCESS_KEY=your_secret_access_key_here
# S3_ENDPOINT=http://localhost:9000  # uncomment for MinIO

# ─── Attachment Limits ────────────────────────────────
ATTACHMENT_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/plain
ATTACHMENT_MAX_FILE_SIZE_BYTES=10485760
ATTACHMENT_MAX_FILES_PER_REQUEST=5
